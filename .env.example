# Telegram bot token from @BotFather. Never commit the real value.
BOT_TOKEN=

# SQLite for local dev (default). For PostgreSQL in production:
# DATABASE_URL=postgresql+asyncpg://safe_pilot:safe_pilot@db:5432/safe_pilot
DATABASE_URL=sqlite+aiosqlite:///./data/safe_pilot.db

# "en" or "ru"
DEFAULT_LANGUAGE=en

# Allowed disagreement (lb) between entered known useful load and the calculated value
# before the bot warns the pilot.
USEFUL_LOAD_TOLERANCE_LB=5.0

LOG_LEVEL=INFO
